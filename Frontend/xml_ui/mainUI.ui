                                  <property name="styleSheet">
                                   <string notr="true">QComboBox {
    background: white;
    border: 2px solid  rgb(199, 214, 255);
    border-radius: 8px;

    padding-left: 16px;
    padding-right: 35px;
    min-height: 38px;

    font-size: 16px;
    color: #2B2B2B;

    outline: none;
}


QComboBox:hover {
    border: 1px solid #D8D8D8;
}


QComboBox:focus {
    border: 1px solid #D0D0D0;
}


/* Arrow button area */
QComboBox::drop-down {
    border: none;
    width: 28px;
    subcontrol-origin: padding;
    subcontrol-position: top right;
}


/* Arrow icon */
QComboBox::down-arrow {
    image: url(../assests/arrow.png);   /* your arrow icon */
    width: 12px;
    height: 12px;
}


/* Popup list */
QComboBox QAbstractItemView {
    background: white;

    border: 1px solid #EAEAEA;
    border-radius: 5px;

    padding: 8px;

    outline: none;

    selection-background-color: rgb(0, 170, 255);
    selection-color: #2B2B2B;

    font-size: 16px;

}


/* Each item */
QComboBox QAbstractItemView::item {
    min-height: 50px;

    border-radius: 8px;

    padding-left: 14px;
    padding-right: 14px;

    margin: 2px;
}


/* Hover item */
QComboBox QAbstractItemView::item:hover {
    background: #F7F7F7;
}


/* Selected item */
QComboBox QAbstractItemView::item:selected {
    background: #F5F5F5;

    border-left: 4px solid #0078FF;

    padding-left: 10px;
}
</string>
